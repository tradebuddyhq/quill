{
  "If Statement": {
    "prefix": "if",
    "body": ["if ${1:condition}:", "  ${2:body}"],
    "description": "If statement"
  },
  "If Otherwise": {
    "prefix": "ifelse",
    "body": ["if ${1:condition}:", "  ${2:body}", "otherwise:", "  ${3:else_body}"],
    "description": "If/otherwise statement"
  },
  "For Each Loop": {
    "prefix": "for",
    "body": ["for each ${1:item} in ${2:list}:", "  ${3:body}"],
    "description": "For each loop"
  },
  "While Loop": {
    "prefix": "while",
    "body": ["while ${1:condition}:", "  ${2:body}"],
    "description": "While loop"
  },
  "Function": {
    "prefix": "to",
    "body": ["to ${1:name} ${2:params}:", "  ${3:body}"],
    "description": "Function definition"
  },
  "Say": {
    "prefix": "say",
    "body": ["say \"${1:message}\""],
    "description": "Print a message"
  },
  "Variable": {
    "prefix": "var",
    "body": ["${1:name} is ${2:value}"],
    "description": "Variable assignment"
  },
  "List": {
    "prefix": "list",
    "body": ["${1:name} are [${2:items}]"],
    "description": "List variable"
  },
  "Describe Class": {
    "prefix": "describe",
    "body": ["describe ${1:ClassName}:", "  ${2:field} is ${3:default}", "", "  to ${4:method}:", "    ${5:body}"],
    "description": "Class definition"
  },
  "Test": {
    "prefix": "test",
    "body": ["test \"${1:test name}\":", "  ${2:expect something}"],
    "description": "Test block"
  },
  "Expect": {
    "prefix": "expect",
    "body": ["expect ${1:expression}"],
    "description": "Test expectation"
  },
  "Give Back": {
    "prefix": "return",
    "body": ["give back ${1:value}"],
    "description": "Return value"
  },
  "Web Server": {
    "prefix": "server",
    "body": [
      "server on port ${1:3000}:",
      "  route \"GET\" \"/${2:}\":",
      "    respond \"${3:Hello, World!}\"",
      "",
      "  route \"GET\" \"/api/${4:data}\":",
      "    respond ${5:result}"
    ],
    "description": "Server with routes"
  },
  "Route Handler": {
    "prefix": "route",
    "body": [
      "route \"${1:GET}\" \"/${2:path}\":",
      "  ${3:body}",
      "  respond ${4:result}"
    ],
    "description": "Route handler"
  },
  "Database": {
    "prefix": "database",
    "body": [
      "database \"${1:mydb}\":",
      "  ${2:users} are collection:",
      "    ${3:name} is text",
      "    ${4:email} is text"
    ],
    "description": "Database definition"
  },
  "Component": {
    "prefix": "component",
    "body": [
      "describe ${1:MyComponent}:",
      "  state:",
      "    ${2:count} is ${3:0}",
      "",
      "  to render:",
      "    ${4:say my count}"
    ],
    "description": "Component with state and render"
  },
  "Spawn Task": {
    "prefix": "spawn",
    "body": ["spawn ${1:task}"],
    "description": "Spawn an async task"
  },
  "Channel": {
    "prefix": "channel",
    "body": [
      "${1:ch} is channel",
      "send ${2:value} to ${1:ch}",
      "${3:result} is receive from ${1:ch}"
    ],
    "description": "Channel declaration with send/receive"
  },
  "Mock": {
    "prefix": "mock",
    "body": [
      "mock ${1:functionName}:",
      "  give back ${2:value}"
    ],
    "description": "Mock a function in tests"
  },
  "Match Block": {
    "prefix": "match",
    "body": [
      "match ${1:value}:",
      "  when ${2:pattern1}:",
      "    ${3:body1}",
      "  when ${4:pattern2}:",
      "    ${5:body2}",
      "  otherwise:",
      "    ${6:default_body}"
    ],
    "description": "Match/when pattern matching"
  },
  "Use Import": {
    "prefix": "use",
    "body": ["use \"${1:module}\""],
    "description": "Import a module"
  }
}
