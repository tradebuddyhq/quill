{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Quill",
  "scopeName": "source.quill",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#keywords-statement" },
    { "include": "#keywords-operator" },
    { "include": "#keywords-async" },
    { "include": "#keywords-type" },
    { "include": "#keywords-server" },
    { "include": "#keywords-test" },
    { "include": "#special" },
    { "include": "#function-call" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [{
        "name": "comment.line.double-dash.quill",
        "match": "--.*$"
      }]
    },
    "strings": {
      "patterns": [{
        "name": "string.quoted.double.quill",
        "begin": "\"",
        "end": "\"",
        "patterns": [{
          "name": "constant.character.escape.quill",
          "match": "\\\\."
        }, {
          "name": "meta.interpolation.quill",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.quill" } },
          "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.quill" } },
          "patterns": [
            { "include": "#function-call" },
            { "include": "#numbers" },
            { "include": "#special" },
            {
              "name": "variable.other.interpolation.quill",
              "match": "[a-zA-Z_]\\w*"
            },
            { "include": "#operators" }
          ]
        }]
      }]
    },
    "numbers": {
      "patterns": [{
        "name": "constant.numeric.quill",
        "match": "\\b\\d+(\\.\\d+)?\\b"
      }]
    },
    "booleans": {
      "patterns": [{
        "name": "constant.language.boolean.quill",
        "match": "\\b(yes|no|true|false|nothing)\\b"
      }]
    },
    "keywords-control": {
      "patterns": [{
        "name": "keyword.control.quill",
        "match": "\\b(if|otherwise|for|each|in|while|give|back|match|when|loop|repeat|select|cancel|yield)\\b"
      }]
    },
    "keywords-declaration": {
      "patterns": [{
        "name": "keyword.declaration.quill",
        "match": "\\b(to|describe|test|trait|type)\\b"
      }]
    },
    "keywords-statement": {
      "patterns": [{
        "name": "keyword.other.quill",
        "match": "\\b(say|expect|use|new|as|set|mock)\\b"
      }]
    },
    "keywords-operator": {
      "patterns": [{
        "name": "keyword.operator.word.quill",
        "match": "\\b(is|are|and|or|not|greater|less|than|equal|contains)\\b"
      }]
    },
    "keywords-async": {
      "patterns": [{
        "name": "keyword.control.async.quill",
        "match": "\\b(spawn|await|parallel|race|channel|send|receive)\\b"
      }]
    },
    "keywords-type": {
      "patterns": [{
        "name": "support.type.quill",
        "match": "\\b(Partial|Omit|Pick|Record|Readonly|Required)\\b"
      }]
    },
    "keywords-server": {
      "patterns": [{
        "name": "keyword.other.server.quill",
        "match": "\\b(server|database|route|respond|websocket|broadcast|deploy)\\b"
      }]
    },
    "keywords-test": {
      "patterns": [{
        "name": "keyword.other.test.quill",
        "match": "\\b(private|public)\\b"
      }]
    },
    "special": {
      "patterns": [{
        "name": "variable.language.this.quill",
        "match": "\\bmy\\b"
      }]
    },
    "function-call": {
      "patterns": [{
        "match": "\\b([a-zA-Z_]\\w*)\\s*(?=\\()",
        "captures": {
          "1": { "name": "entity.name.function.quill" }
        }
      }]
    },
    "operators": {
      "patterns": [{
        "name": "keyword.operator.arithmetic.quill",
        "match": "[+\\-*/%]"
      }, {
        "name": "keyword.operator.pipe.quill",
        "match": "\\|"
      }, {
        "name": "punctuation.accessor.quill",
        "match": "\\."
      }]
    }
  }
}
