{
  "name": "quill-lang",
  "displayName": "Quill Language",
  "description": "Syntax highlighting and snippets for the Quill programming language",
  "version": "0.1.0",
  "publisher": "tradebuddyhq",
  "repository": {
    "type": "git",
    "url": "https://github.com/tradebuddyhq/quill"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [{
      "id": "quill",
      "aliases": ["Quill", "quill"],
      "extensions": [".quill"],
      "configuration": "./language-configuration.json",
      "icon": {
        "light": "./icon.png",
        "dark": "./icon.png"
      }
    }],
    "grammars": [{
      "language": "quill",
      "scopeName": "source.quill",
      "path": "./syntaxes/quill.tmLanguage.json"
    }],
    "snippets": [{
      "language": "quill",
      "path": "./snippets/quill.json"
    }]
  }
}
